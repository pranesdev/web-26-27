---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/team.css';
---

<BaseLayout title="Team | The People Behind the Work">
  <div class="dsc-marquee-container">
    <div class="dsc-marquee-content">
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
    </div>
  </div>

  <header class="team-header">
    <a href="/" style="display: flex; align-items: center; gap: 8px; color: #fff; text-decoration: none; pointer-events: auto;">
      <img src="/creative-ai/club logo.png" alt="DSC Logo" width="80" height="80" style="height: 80px; object-fit: contain; transform: translateY(-10px);">
    </a>

    <nav class="team-header-nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/#domains">Domains</a>
      <a href="/gallery">Gallery</a>
      <a href="/team" class="active">Team</a>
      <a href="/contact">Contact</a>
    </nav>

    <div style="display: flex; align-items: center; pointer-events: auto;">
      <a href="#" class="team-header-cta">Join Us</a>
      <button class="team-mobile-menu-btn" aria-label="Open navigation menu" style="display: none; background: none; border: none; cursor: pointer; margin-left: 16px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </header>

  <div class="grid-overlay">
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
    <div class="grid-line"></div>
  </div>

  <main class="team-container">
    
    <!-- Header Section -->
    <div class="header-section">
      <h1>THE STUDENT LEADERS<br>OF DSC.</h1>
      <p class="desc">
        Developer Students Club is built by a team of passionate developers, designers, and innovators who believe in the power of community-driven learning.
      </p>
      <p class="desc">
        We bring together expertise across web development, machine learning, cloud computing, and UI/UX design — unified by a shared commitment to building impactful solutions.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="team-members">
      
      <!-- Row 1 -->
      <div class="member-card" style="grid-column: 1; grid-row: 1;">
        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="David Aghaei">
        <div class="member-info">
          <h2>DAVID AGHAEI</h2>
          <p>PRESIDENT</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 2; grid-row: 1;">
        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Daniel Dayan">
        <div class="member-info">
          <h2>DANIEL DAYAN</h2>
          <p>VICE PRESIDENT</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 3; grid-row: 1; margin-top: 240px;">
        <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Christopher Kovel">
        <div class="member-info">
          <h2>CHRISTOPHER KOVEL</h2>
          <p>TECHNICAL LEAD</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 4; grid-row: 1; margin-top: 240px;">
        <img src="https://images.unsplash.com/photo-1552058544-f2b08422138a?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Joseph Doyle">
        <div class="member-info">
          <h2>JOSEPH DOYLE</h2>
          <p>EVENTS LEAD</p>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="member-card" style="grid-column: 1; grid-row: 2;">
        <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Steven Lopez">
        <div class="member-info">
          <h2>STEVEN LOPEZ</h2>
          <p>DESIGN LEAD</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 2; grid-row: 2;">
        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Jenna Hornstock">
        <div class="member-info">
          <h2>JENNA HORNSTOCK</h2>
          <p>PR & OUTREACH LEAD</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 4; grid-row: 2;">
        <img src="https://images.unsplash.com/photo-1504257432389-52343af06ae3?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Justin Lee">
        <div class="member-info">
          <h2>JUSTIN LEE</h2>
          <p>WEB DEVELOPMENT LEAD</p>
        </div>
      </div>

      <!-- Row 3 -->
      <div class="member-card" style="grid-column: 2; grid-row: 3;">
        <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Briana Land">
        <div class="member-info">
          <h2>BRIANA LAND</h2>
          <p>COMMUNITY MANAGER</p>
        </div>
      </div>

      <div class="member-card" style="grid-column: 3; grid-row: 3;">
        <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Marrisa Yurcek">
        <div class="member-info">
          <h2>MARRISA YURCEK</h2>
          <p>OPERATIONS LEAD</p>
        </div>
      </div>

    </div>

    <!-- Bottom Section -->
    <div class="bottom-section">
      <div class="cta-box">
        <h2>READY TO BUILD<br>WITH US?</h2>
        <p>We're building a vibrant tech community and looking for students<br>who share our passion. Bring your curiosity, your drive, and your<br>commitment to learning and growing together.</p>
        <a href="#" class="apply-link">APPLY TO JOIN &rarr;</a>
      </div>
      <div class="team-photo-box">
        <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Team Group Photo">
      </div>
    </div>
  </main>
</BaseLayout>
