---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import SideRays from '../components/SideRays.tsx';
import Watermark from '../components/Watermark.tsx';
import TeamArtCutouts from '../components/TeamArtCutouts.tsx';
import TeamShowcase from '../components/TeamShowcase.tsx';
import TechParticles from '../components/TechParticles.tsx';
import '../styles/contact.css';
---

<BaseLayout title="Team — Developer Students Club | SRM IST Ramapuram" description="Meet the passionate core team of student leaders, developers, designers, and organizers behind the Developer Students Club (DSC) at SRM IST Ramapuram.">

  <!-- Interactive WebGL SideRays Background (React Island) -->
  <div class="side-rays-bg">
    <SideRays
      client:only="react"
      speed={1.2}
      rayColor1="#1dd1a1"
      rayColor2="#00f2fe"
      intensity={1.2}
      spread={2.5}
      origin="top-right"
      tilt={0}
      saturation={1.5}
      blend={0.75}
      falloff={1.6}
      opacity={0.65}
    />
  </div>

  <!-- Interactive Background Canvas Particles (React Island) -->
  <TechParticles client:load />

  <!-- Decorative Corner Circuit Board Graphics -->
  <svg class="corner-graphic corner-top-left" width="250" height="250" viewBox="0 0 250 250" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,50 L100,50 L150,100 L220,100" stroke="rgba(232, 237, 233, 0.4)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M60,0 L60,80 L100,120 L150,120" stroke="rgba(232, 237, 233, 0.25)" stroke-width="1" stroke-linecap="round" />
    <circle cx="220" cy="100" r="3" fill="#1dd1a1" />
    <circle cx="150" cy="120" r="2" fill="rgba(232, 237, 233, 0.6)" />
  </svg>

  <svg class="corner-graphic corner-top-right" width="250" height="250" viewBox="0 0 250 250" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M250,50 L150,50 L100,100 L30,100" stroke="rgba(232, 237, 233, 0.4)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M190,0 L190,80 L150,120 L100,120" stroke="rgba(232, 237, 233, 0.25)" stroke-width="1" stroke-linecap="round" />
    <circle cx="30" cy="100" r="3" fill="#1dd1a1" />
    <circle cx="100" cy="120" r="2" fill="rgba(232, 237, 233, 0.6)" />
  </svg>

  <!-- Marquee Ticker -->
  <div class="dsc-marquee-container">
    <div class="dsc-marquee-content">
      <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      
      <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
    </div>
  </div>

  <!-- Navigation (React Island) -->
  <Header client:load active="team" />

  <main class="contact-container" style="max-width: 1100px;">
    <div class="contact-layout-wrapper" style="--watermark-size: clamp(6.5rem, 22vw, 16rem);">
      
      <!-- Reusable 3D Parallax Watermark component -->
      <Watermark client:load text="TEAM" />

      <!-- Interactive Background Art Cutouts (React Island) -->
      <TeamArtCutouts client:load />

      <!-- Title / Intro Header -->
      <section class="team-header-intro">
        <h1 class="left-title text-center" style="font-size: clamp(2.2rem, 5vw, 3.2rem); margin-bottom: 16px; overflow: hidden;">
          {Array.from("The Minds Behind DSC").map((char) => (
            <span class="reveal-char" style="display: inline-block; white-space: pre;">{char}</span>
          ))}
        </h1>
        <p class="left-subtext text-center intro-subtext" style="max-width: 600px; margin: 0 auto 48px; font-size: 16px; opacity: 0; filter: blur(4px);">
          Developer Students Club is built by a team of passionate developers, designers, and innovators who believe in the power of community-driven learning.
        </p>
      </section>

      <!-- Team Showcase Cards Grid (React Island) -->
      <section class="team-showcase-section" style="position: relative; z-index: 10;">
        <TeamShowcase client:load />
      </section>

      <!-- Bottom Interactive Call to Action Block -->
      <section class="team-bottom-cta">
        <div class="team-cta-box">
          <div class="team-cta-text">
            <h2>Ready to build with us?</h2>
            <p>We're building a vibrant tech community and looking for students who share our passion. Bring your curiosity, your drive, and your commitment to learning and growing together.</p>
          </div>
          <div class="team-cta-action">
            <a href="/contact" class="team-cta-btn">
              <span>Get in Touch</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>
        </div>
      </section>

    </div>
  </main>

  <!-- Footer (React Island) -->
  <Footer client:load active="team" />

</BaseLayout>

<style>
  .text-center {
    text-align: center;
  }

  .team-header-intro {
    position: relative;
    z-index: 10;
  }

  .team-bottom-cta {
    position: relative;
    z-index: 10;
    margin-top: 80px;
    padding-bottom: 20px;
    width: 100%;
  }

  .team-cta-box {
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.02'/%3E%3C/svg%3E"),
      linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0) 100%);
    background-color: var(--card-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    text-align: left;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .team-cta-box:hover {
    border-color: rgba(29, 209, 161, 0.25);
    box-shadow: 0 12px 40px rgba(29, 209, 161, 0.06);
  }

  .team-cta-text h2 {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 1.8rem;
    color: var(--text-color);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .team-cta-text p {
    color: var(--text-muted);
    font-size: 14.5px;
    line-height: 1.6;
    max-width: 580px;
    margin: 0;
  }

  .team-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ffffff;
    color: #080d0b;
    border: none;
    border-radius: 10px;
    padding: 16px 28px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.25s, transform 0.25s;
    white-space: nowrap;
  }

  .team-cta-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    color: #080d0b;
  }

  .team-cta-btn:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .team-cta-box {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 30px;
    }
    
    .team-cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  window.addEventListener('DOMContentLoaded', () => {
    const timeline = gsap.timeline();
    timeline.fromTo(".reveal-char",
      { opacity: 0, y: 35, filter: 'blur(8px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.8, stagger: 0.03, ease: 'power4.out' }
    );
    timeline.fromTo(".intro-subtext",
      { opacity: 0, y: 15, filter: 'blur(4px)' },
      { opacity: 0.6, y: 0, filter: 'blur(0px)', duration: 0.8, ease: 'power2.out' },
      "-=0.45"
    );
  });
</script>
