---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import '../styles/about.css';
---

<BaseLayout title="About | Shaping The Future">
  <!-- Marquee -->
  <div class="dsc-marquee-container">
    <div class="dsc-marquee-content">
      <div style="display: flex; align-items: center">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <Header client:load active="about" />

  <!-- Hero Section -->
  <header class="about-hero">
    <div class="hero-image-container">
      <div class="checkered-overlay"></div>
      <img src="https://images.unsplash.com/photo-1540747913346-19e32dc3e97e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Action Shot" class="hero-bg">
    </div>
    <h1 class="massive-text">SHAPING THE FUTURE OF FAN EXPERIENCE</h1>
  </header>

  <!-- Intro Block -->
  <section class="intro-block">
    <div class="intro-col text-left">
      <p>WE ARE A GLOBAL AGENCY DRIVEN BY PASSION AND INNOVATION, CREATING EXPERIENCES THAT CONNECT FANS TO THE SPORTS THEY LOVE IN UNPRECEDENTED WAYS.</p>
    </div>
    <div class="intro-col center-image">
      <img src="https://images.unsplash.com/photo-1526232761682-d26e03ac148e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Person holding ball">
    </div>
    <div class="intro-col text-right">
      <p>OUR TEAM BRINGS TOGETHER EXPERTISE IN STRATEGY, DESIGN, AND TECHNOLOGY TO DELIVER CUTTING-EDGE SOLUTIONS FOR BRANDS WORLDWIDE.</p>
    </div>
  </section>

  <!-- Latest Work -->
  <section class="latest-work">
    <h2 class="massive-text">LATEST WORK</h2>
    <div class="work-grid">
      <div class="work-item full-width"><img src="https://images.unsplash.com/photo-1535139262971-c51845709a48?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Golf Crowd"></div>
      <div class="work-item half-width"><img src="https://images.unsplash.com/photo-1518091043644-c1d4457512c6?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Soccer Crowd"></div>
      <div class="work-item half-width"><img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Soccer Player"></div>
      <div class="work-item full-width"><img src="https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Field"></div>
    </div>
  </section>

  <!-- We Keep Good -->
  <section class="partners">
    <h2 class="massive-text">WE KEEP GOOD</h2>
    <div class="logos-container">
      <div class="logo">LIV GOLF</div>
      <div class="logo">Spotify</div>
      <div class="logo">WSL</div>
    </div>
  </section>

  <!-- Insights & Opinions -->
  <section class="insights">
    <h2 class="massive-text">INSIGHTS & OPINIONS</h2>
    <div class="insights-grid">
      <div class="insight-card">
        <h3 class="insight-date">27.05</h3>
        <p class="insight-title">The evolution of digital fan engagement in modern sports stadiums.</p>
        <img src="https://images.unsplash.com/photo-1522778119026-d647f0596c20?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Stadium">
      </div>
      <div class="insight-card">
        <h3 class="insight-date">21.05</h3>
        <p class="insight-title">How augmented reality is transforming the broadcast experience.</p>
        <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="AR">
      </div>
      <div class="insight-card">
        <h3 class="insight-date">19.05</h3>
        <p class="insight-title">Creating personalized journeys for the next generation of fans.</p>
        <img src="https://images.unsplash.com/photo-1551698618-1dfe5d97d256?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Fans">
      </div>
    </div>
    <div class="btn-container">
      <a href="#" class="primary-btn">Read all news</a>
    </div>
  </section>

  <!-- Bottom Mask -->
  <section class="bottom-mask">
    <div class="mask-text-container">
      <h1 class="mask-text">WOW</h1>
    </div>
  </section>

  <script src="../scripts/about.js"></script>
</BaseLayout>
