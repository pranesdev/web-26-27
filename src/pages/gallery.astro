---
import BaseLayout from '../layouts/BaseLayout.astro';
import CardCarousel from '../components/CardCarousel';
---

<BaseLayout title="Gallery | Developer Students Club">
  <style>
    @keyframes dsc-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .dsc-marquee-container {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: 40px;
      overflow: hidden;
      background: #111827;
      color: #fff;
      display: flex;
      align-items: center;
      white-space: nowrap;
      z-index: 150;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      font-family: 'Inter', sans-serif;
    }
    .dsc-marquee-content {
      display: flex;
      animation: dsc-marquee 45s linear infinite;
    }
    .dsc-marquee-item {
      display: flex;
      align-items: center;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .dsc-marquee-star {
      color: #14a3a3;
      margin: 0 32px;
      font-size: 14px;
    }

    /* Header specific styles */
    .team-header {
      position: absolute;
      top: 40px;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px;
      pointer-events: none;
      font-family: 'Inter', sans-serif;
    }
    
    .team-header-nav {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 100;
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 9999px;
      padding: 8px;
      display: flex;
      align-items: center;
      gap: 4px;
      pointer-events: auto;
    }

    .team-header-nav a {
      padding: 6px 16px;
      border-radius: 9999px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      color: rgba(255,255,255,0.8);
    }

    .team-header-nav a:hover, .team-header-nav a.active {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }

    .team-header-cta {
      background: #fff;
      color: #111827;
      font-size: 14px;
      font-weight: 600;
      padding: 10px 24px;
      border-radius: 9999px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .team-header-cta:hover {
      background: #f3f4f6;
    }

    @media (max-width: 768px) {
      .team-header-nav { display: none; }
      .team-header-cta { display: none; }
      .team-mobile-menu-btn { display: flex !important; }
    }
  </style>

  <div class="dsc-marquee-container">
    <div class="dsc-marquee-content">
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
      <div style="display: flex; align-items: center;">
        <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
        <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      </div>
    </div>
  </div>

  <header class="team-header">
    <a href="/" style="display: flex; align-items: center; gap: 8px; color: #fff; text-decoration: none; pointer-events: auto;">
      <img src="/creative-ai/club logo.png" alt="DSC Logo" style="height: 80px; object-fit: contain; transform: translateY(-10px);">
    </a>

    <nav class="team-header-nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/#domains">Domains</a>
      <a href="/gallery" class="active">Gallery</a>
      <a href="/team">Team</a>
    </nav>

    <div style="display: flex; align-items: center; pointer-events: auto;">
      <a href="#" class="team-header-cta">Join Us</a>
      <button class="team-mobile-menu-btn" style="display: none; background: none; border: none; cursor: pointer; margin-left: 16px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </header>

  <!-- ========== REACT CAROUSEL SECTION ========== -->
  <section id="react-carousel-root" style="width: 100vw; height: 100vh; overflow: hidden;">
    <CardCarousel client:load />
  </section>

</BaseLayout>
