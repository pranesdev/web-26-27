---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
---

<BaseLayout>
  <!-- Hero Component (React Island) -->
  <Hero client:load />

  <!-- ========== CREATIVE AI SECTION ========== -->
  <section class="creative-ai-section">
    <div class="ca-grid">
      <!-- Row 1 -->
      <div class="ca-cell ca-white-block ca-span-2">
        <h2 class="ca-heading">Fostering developer<br>innovation</h2>
        <p class="ca-text">Developer Students Club, SRM IST Ramapuram provides<br>a collaborative space for students to learn, build, and grow<br>together, bridging the gap between theory and practice.</p>
      </div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>

      <!-- Row 2 -->
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-white-block ca-center-1">
        <h3 class="ca-subheading">Hands-on learning &<br>workshops</h3>
        <p class="ca-text">Master modern frameworks, tools, and<br>platforms through peer-led study groups and<br>interactive tech workshops.</p>
      </div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>

      <!-- Row 3 -->
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-white-block ca-right-1">
        <h3 class="ca-subheading">Real-world project<br>development</h3>
        <p class="ca-text">Apply theoretical concepts to solve real<br>local problems, collaborate in teams, and<br>build impactful open-source projects.</p>
      </div>

      <!-- Row 4 -->
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-empty"></div>
      <div class="ca-cell ca-white-block ca-center-2">
        <h3 class="ca-subheading">Global network &<br>mentorship</h3>
        <p class="ca-text">Connect with developers worldwide, learn<br>from industry experts, and prepare for a<br>career in the tech industry.</p>
      </div>
      <div class="ca-cell ca-empty"></div>
    </div>
  </section>

  <!-- ========== PARTNERSHIP SECTION ========== -->
  <section class="partnership-section">
    <div class="partnership-content reveal">
      <h2 class="partnership-heading">Backed by Google Developers</h2>
      <p class="partnership-subheading">We are a university-based community group for students. Join our chapter to learn, connect, and build tech solutions for local businesses and your community.</p>
      <a href="#" class="btn-partnership">Join Our Chapter</a>
    </div>
  </section>

  <!-- ========== CONTRA LABS FOOTER ========== -->
  <footer class="contra-footer" id="contact">
    <div class="contra-content">
      <h2 class="contra-logo" style="font-family: 'Playfair Display', Georgia, serif; font-weight: 500; font-size: 2.5rem; letter-spacing: normal;">Developer Students Club</h2>
      <p class="contra-subtitle">SRM IST, Ramapuram</p>
      
      <div class="contra-socials">
        <a href="#" aria-label="X">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>

        <a href="#" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a href="#" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>

      <div class="contra-links">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#domains">Domains</a>
        <a href="/gallery">Gallery</a>
      </div>
    </div>

    <video src="https://framerusercontent.com/assets/hmg5dFU33RwVgzS4V0wrSxuKJ3E.mp4" class="contra-art" autoplay loop muted playsinline preload="none"></video>
  </footer>

  <!-- Main Behavior Script -->
  <script src="../scripts/main.js"></script>
</BaseLayout>
