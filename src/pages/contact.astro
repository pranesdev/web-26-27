---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIconBtn from '../components/SocialIconBtn.tsx';
import MapCard from '../components/MapCard.tsx';
import ContactFormCard from '../components/ContactFormCard.tsx';
import ContactWatermark from '../components/ContactWatermark.tsx';
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import ContactArtCutouts from '../components/ContactArtCutouts.tsx';
import SideRays from '../components/SideRays.tsx';
import '../styles/contact.css';
---

<BaseLayout title="Contact — AI Automation SaaS" description="Get in touch with our team to transform your business operations with custom AI automation workflows.">

  <!-- Interactive WebGL SideRays Background (React Island) -->
  <div class="side-rays-bg">
    <SideRays
      client:only="react"
      speed={1.2}
      rayColor1="#1dd1a1"
      rayColor2="#00f2fe"
      intensity={1.2}
      spread={2.5}
      origin="top-right"
      tilt={0}
      saturation={1.5}
      blend={0.75}
      falloff={1.6}
      opacity={0.65}
    />
  </div>

  <!-- Decorative Corner Circuit Board Graphics -->
  <svg class="corner-graphic corner-top-left" width="250" height="250" viewBox="0 0 250 250" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,50 L100,50 L150,100 L220,100" stroke="rgba(232, 237, 233, 0.4)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M60,0 L60,80 L100,120 L150,120" stroke="rgba(232, 237, 233, 0.25)" stroke-width="1" stroke-linecap="round" />
    <circle cx="220" cy="100" r="3" fill="#1dd1a1" />
    <circle cx="150" cy="120" r="2" fill="rgba(232, 237, 233, 0.6)" />
  </svg>

  <svg class="corner-graphic corner-top-right" width="250" height="250" viewBox="0 0 250 250" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M250,50 L150,50 L100,100 L30,100" stroke="rgba(232, 237, 233, 0.4)" stroke-width="1.5" stroke-linecap="round" />
    <path d="M190,0 L190,80 L150,120 L100,120" stroke="rgba(232, 237, 233, 0.25)" stroke-width="1" stroke-linecap="round" />
    <circle cx="30" cy="100" r="3" fill="#1dd1a1" />
    <circle cx="100" cy="120" r="2" fill="rgba(232, 237, 233, 0.6)" />
  </svg>


  <!-- Marquee Ticker -->
  <div class="dsc-marquee-container">
    <div class="dsc-marquee-content">
      <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
      
      <div class="dsc-marquee-item">UPCOMING HACKATHON: CODEFEST 2026</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">NEW WORKSHOPS EVERY WEEK</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">JOIN THE OPEN SOURCE REVOLUTION</div><div class="dsc-marquee-star">★</div>
      <div class="dsc-marquee-item">EMPOWERING STUDENT DEVELOPERS</div><div class="dsc-marquee-star">★</div>
    </div>
  </div>

  <!-- Navigation & Mobile Menu (React Island) -->
  <Header client:load active="contact" />


  <main class="contact-container">
    <div class="contact-layout-wrapper">
      <!-- Decorative Background Watermark (Interactive React Island) -->
      <ContactWatermark client:load />

      <!-- Interactive Background Art Cutouts (React Island) -->
      <ContactArtCutouts client:load />

      <div class="contact-grid">
        <section class="left-col">
          <h1 class="left-title">Get in touch</h1>
          <p class="left-subtext">Have questions or want to collaborate with Developer Students Club at SRM IST Ramapuram?</p>

          <!-- Social Icons Row for Redirects (React Islands) -->
          <div class="contact-socials-row">
            <SocialIconBtn client:load type="email" href="mailto:dsc.srmrmp@gmail.com" value="dsc.srmrmp@gmail.com" label="Email DSC" />
            <SocialIconBtn client:load type="instagram" href="https://instagram.com/dscsrmrmp" value="@dscsrmrmp" label="Instagram" />
            <SocialIconBtn client:load type="linkedin" href="https://linkedin.com/company/dscsrmrmp" value="DSC SRM Ramapuram" label="LinkedIn" />
            <SocialIconBtn client:load type="twitter" href="https://x.com/dscsrmrmp" value="@dscsrmrmp" label="X (Twitter)" />
          </div>

          <!-- Integrated Dark Map Card (React Island) -->
          <MapCard client:load />

          <!-- Address Block below the MapCard -->
          <div class="map-address-block">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <p>SRM IST Ramapuram, Bharathi Salai, Ramapuram, Chennai, Tamil Nadu 600089</p>
          </div>
        </section>

        <!-- Right Column: Card with Contact Form (React Island) -->
        <section class="right-col">
          <ContactFormCard client:load />
        </section>
      </div>
    </div>
  </main>

  <!-- Footer (React Island) -->
  <Footer client:load active="contact" />

  <script>
    // Social icon GSAP hover — now handled by SocialIconBtn.tsx island

    // Map pin hover + zoom — now handled by MapCard.tsx island

    // Form submit + toast — now handled by ContactFormCard.tsx island

    // Mobile menu drawer toggle — now handled by Header.tsx island
  </script>
</BaseLayout>
