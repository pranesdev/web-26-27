---
interface Props {
  address?: string;
  height?: string;
}

const { 
  address = "SRM IST Ramapuram, Bharathi Salai, Ramapuram, Chennai, Tamil Nadu 600089",
  height = "340px"
} = Astro.props;
---
<div class="map-card" style={`height: ${height};`}>
  <!-- Official Pinpointed Iframe Map -->
  <iframe 
    src="https://maps.google.com/maps?q=13.0322541,80.1807376(SRM+Institute+of+Science+and+Technology+Ramapuram)&z=16&output=embed" 
    width="100%" 
    height="100%" 
    style="border:0; filter: invert(0.9) hue-rotate(180deg) contrast(1.2) brightness(0.9); opacity: 0.85;" 
    allowfullscreen="" 
    loading="lazy" 
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
</div>

{address && (
  <div class="map-address-block">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
      <circle cx="12" cy="10" r="3" />
    </svg>
    <p>{address}</p>
  </div>
)}
